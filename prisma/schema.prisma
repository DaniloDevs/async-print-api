generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum eventStatus {
  ACTIVE
  INACTIVE
  DRAFT
  FINISHED
  CANCELED
}

enum leadTechnical {
  ENF
  INF
  ADM
  NONE
}

enum leadOringen {
  QRCODE
  INSTAGRAM
  MANUAL
}

enum leadSegment {
  NONE
  JARDIM_1
  JARDIM_2
  ANO_1_FUNDAMENTAL
  ANO_2_FUNDAMENTAL
  ANO_3_FUNDAMENTAL
  ANO_4_FUNDAMENTAL
  ANO_5_FUNDAMENTAL
  ANO_6_FUNDAMENTAL
  ANO_7_FUNDAMENTAL
  ANO_8_FUNDAMENTAL
  ANO_9_FUNDAMENTAL
  ANO_1_MEDIO
  ANO_2_MEDIO
  ANO_3_MEDIO
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PrinterType {
  THERMAL
  INKJET
  LASER
  PDF
  NETWORK
}

enum PrinterStatus {
  DISCONNECTED
  CONNECTED
  PRINTING
}

enum Role {
  ADMIN
  MEMBER
}

model Event {
  id        String      @id @default(cuid())
  title     String
  slug      String      @unique
  bannerKey String?
  status    eventStatus @default(DRAFT)
  startAt   DateTime
  endsAt    DateTime
  createdAt DateTime    @default(now())

  leads    Lead[]
  printers Printer[]

  @@map("events")
}

model Lead {
  id                String  @id @default(cuid())
  name              String
  phone             String
  email             String
  intentionNextYear Boolean @default(true)

  origin    leadOringen
  technical leadTechnical
  segment   leadSegment

  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([email, eventId])
  @@unique([phone, eventId])
  @@index([eventId])
  @@map("leads")
}

model Job {
  id      String    @id @default(uuid())
  name    String
  payload Json
  status  JobStatus @default(PENDING)

  attempts    Int @default(0)
  maxAttempts Int

  createdAt   DateTime  @default(now())
  processedAt DateTime?
  completedAt DateTime?
  error       String?

  @@index([status, createdAt])
}

model Printer {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  path        String
  description String?

  type   PrinterType
  status PrinterStatus @default(DISCONNECTED)

  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}



model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  // role          Role     @default(MEMBER)

  @@map("users")
}
